  "scoring": {
    "thresholds": {
      "portal_hypertension_present": 2,
      "high_variceal": 6,
      "probable_variceal_with_ph": 5,
      "probable_non_variceal": 4
    },
    "derived_rules": [
      {
        "id": "pediatric_ehpvo_boost",
        "when_all_flags": ["pediatric_patient", "portal_cavernoma"],
        "add_scores": {
          "variceal": 1
        },
        "explanation": "Педиатрический EHPVO усиливает вероятность варикозного источника."
      },
      {
        "id": "spleno_thrombocytopenia_combo",
        "when_all_flags": ["splenomegaly", "thrombocytopenia"],
        "add_scores": {
          "variceal": 1,
          "portal_hypertension": 1
        },
        "explanation": "Спленомегалия с тромбоцитопенией поддерживает портальную гипертензию."
      },
      {
        "id": "portal_cavernoma_known_varices_bleeding_combo",
        "when_all_flags": ["portal_cavernoma", "known_varices"],
        "when_any_flags": ["hematemesis", "melena"],
        "force_path": "high_probable_variceal",
        "explanation": "Portal cavernoma + известные вариксы + кровотечение = очень высокая вероятность варикозного источника."
      }
    ]
  },
